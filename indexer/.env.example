# Provider: "gemini" (free tier) or "openai". If unset, gemini is used when
# GEMINI_API_KEY is present, otherwise openai.
# LLM_PROVIDER=gemini

# Gemini free tier — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# Embeddings can use a different provider than the LLM. The Gemini free tier
# counts every text of a batch against its 1,000 requests/DAY embedding quota,
# so real corpora need paid embeddings; text-embedding-3-small costs ~$0.02/1M
# tokens. IMPORTANT: the index must be queried with the same embedding model
# it was built with — changing this after indexing requires re-indexing.
# EMBED_PROVIDER=openai

# Optional: override the extraction LLM. Default for gemini is
# gemini-3.1-flash-lite — on this account's free tier it is the only text model
# with a usable daily quota (15 RPM / 500 RPD; the other flash models allow 20/day).
# LLM_MODEL=gemini-3.1-flash-lite
